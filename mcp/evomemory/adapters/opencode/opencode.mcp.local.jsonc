{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "evomemory": {
      "type": "local",
      "enabled": true,
      "command": [
        "python3",
        "/home/mechrevo/.config/opencode/mcp/evomemory/interfaces/mcp/server.py",
        "--host",
